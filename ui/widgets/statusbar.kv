#:import dp kivy.metrics.dp

<StatusBar>

    size_hint_y: None
    height: dp(28)

    padding: dp(8)

    Label:
        id: file_label
        text: "No document"
        halign: "left"

    Label:
        id: state_label
        text: "Ready"

    Label:
        id: rows_label
        text: "0 rows"
        halign: "right"