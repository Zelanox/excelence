#:import dp kivy.metrics.dp

<StatusBar>

    size_hint_y: None
    height: dp(28)

    padding: dp(8)

    Label:
        id: status_label
        text: "No document loaded"
        halign: "left"

    Label:
        id: connection_label
        text: "Offline"

    Label:
        id: rows_label
        text: "0 rows"
        halign: "right"