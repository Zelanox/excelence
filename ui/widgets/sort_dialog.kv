#:import dp kivy.metrics.dp

<SortDialog>

    title: "Sort"

    size_hint: .6, .6

    auto_dismiss: True

    BoxLayout:

        orientation: "vertical"

        size_hint_y: None
        height: self.minimum_height

        spacing: dp(6)
        padding: dp(12)

        Label:
            text: "Priority 1"
            font_name: "assets/fonts/Tajawal-Regular.ttf"

        Spinner:
            id: column1
            text: ""
            option_cls: "ArabicSpinnerOption"
            font_name: "assets/fonts/Tajawal-Regular.ttf"

        Spinner:
            id: order1
            text: "Ascending"
            values: ["Ascending", "Descending"]
            option_cls: "ArabicSpinnerOption"
            font_name: "assets/fonts/Tajawal-Regular.ttf"


        Label:
            text: "Priority 2"
            font_name: "assets/fonts/Tajawal-Regular.ttf"
            size_hint_y: None
            height: dp(28)

        Spinner:
            id: column2
            text: ""
            option_cls: "ArabicSpinnerOption"
            font_name: "assets/fonts/Tajawal-Regular.ttf"
            size_hint_y: None
            height: dp(28)

        Spinner:
            id: order2
            text: "Ascending"
            values: ["Ascending", "Descending"]
            option_cls: "ArabicSpinnerOption"
            font_name: "assets/fonts/Tajawal-Regular.ttf"
            size_hint_y: None
            height: dp(28)


        Label:
            text: "Priority 3"
            font_name: "assets/fonts/Tajawal-Regular.ttf"
            size_hint_y: None
            height: dp(28)

        Spinner:
            id: column3
            text: ""
            option_cls: "ArabicSpinnerOption"
            font_name: "assets/fonts/Tajawal-Regular.ttf"
            size_hint_y: None
            height: dp(28)

        Spinner:
            id: order3
            text: "Ascending"
            values: ["Ascending", "Descending"]
            option_cls: "ArabicSpinnerOption"
            font_name: "assets/fonts/Tajawal-Regular.ttf"
            size_hint_y: None
            height: dp(28)


        Button:
            text: "Apply"
            on_release: root.apply()
            font_name: "assets/fonts/Tajawal-Regular.ttf"
            size_hint_y: None
            height: dp(28)