#:import dp kivy.metrics.dp

<SearchBar>

    size_hint_y: None
    height: dp(42)

    spacing: dp(6)
    padding: dp(6)

    font_name: "assets/fonts/Tajawal-Regular.ttf"

    TextInput:
        id: search_input
        hint_text: "Search..."
        multiline: False
        on_text: root.search_changed(self.text)
        font_name: "assets/fonts/Tajawal-Regular.ttf"